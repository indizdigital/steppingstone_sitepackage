        <target>Mobile oder Telefon</target>
      </trans-unit>
      <trans-unit id="element.telephone-1.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. +41 79 123 45 67</source>
        <target>z.B. +41 79 123 45 67</target>
      </trans-unit>

      <trans-unit id="element.email-1.properties.label">
        <source>Email</source>
        <target>E-Mail</target>
      </trans-unit>
      <trans-unit id="element.email-1.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. maximilian.mustermann@musterfirma.ch</source>
        <target>z.B. maximilian.mustermann@musterfirma.ch</target>
      </trans-unit>

      <trans-unit id="element.checkbox-1.properties.label">
        <source>I have read the general terms and conditions and agree.</source>
        <target>Ich habe die allgemeinen Geschäftsbedingungen gelesen und stimme diesen zu.</target>
      </trans-unit>

      <trans-unit id="element.checkbox-2.properties.label">
        <source>I would like to receive the newsletter.</source>
        <target>Ich möchte den Newsletter erhalten.</target>
      </trans-unit>

      <trans-unit id="element.textarea-1.properties.label">
        <source>Questions or comments</source>
        <target>Fragen oder Kommentare</target>
      </trans-unit>
