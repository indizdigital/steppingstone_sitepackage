      <trans-unit id="element.text-1.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. Maximilian</source>
        <target>z.B. Maximilian</target>
      </trans-unit>

      <trans-unit id="element.text-2.properties.label">
        <source>Surname</source>
        <target>Nachname</target>
      </trans-unit>
      <trans-unit id="element.text-2.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. Mustermann</source>
        <target>z.B. Mustermann</target>
      </trans-unit>

      <trans-unit id="element.text-3.properties.label">
