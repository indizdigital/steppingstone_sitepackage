      </trans-unit>

      <trans-unit id="element.text-4.properties.label">
        <source>Address line 2</source>
        <target>Adresszeile 2</target>
      </trans-unit>
      <trans-unit id="element.text-4.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. 2nd floor or c/o Musterfirma AG</source>
        <target>z.B. 2. Stock oder c/o Musterfirma AG</target>
      </trans-unit>

      <trans-unit id="element.text-5.properties.label">
        <source>Postcode</source>
        <target>Postleitzahl</target>
      </trans-unit>
      <trans-unit id="element.text-5.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. 3000</source>
        <target>z.B. 3000</target>
      </trans-unit>

      <trans-unit id="element.text-6.properties.label">
        <source>Location</source>
        <target>Ort</target>
      </trans-unit>
      <trans-unit id="element.text-6.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. Bern</source>
        <target>z.B. Bern</target>
      </trans-unit>

      <trans-unit id="element.text-7.properties.label">
        <source>Country</source>
        <target>Land</target>
      </trans-unit>
      <trans-unit id="element.text-7.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. Switzerland</source>
        <target>z.B. Schweiz</target>
      </trans-unit>

      <trans-unit id="element.telephone-1.properties.label">
