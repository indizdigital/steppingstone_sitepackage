      </trans-unit>
      <trans-unit id="element.steppingStoneTest.renderingOptions.submitButtonLabel">
        <source>Send</source>
        <target>Absenden</target>
      </trans-unit>

      <trans-unit id="element.name.properties.label">
        <source>Company</source>
        <target>Firma</target>
      </trans-unit>
      <trans-unit id="element.name.properties.fluidAdditionalAttributes.placeholder">
        <source>e.g. Musterfirma AG</source>
        <target>z.B. Musterfirma AG</target>
      </trans-unit>

      <trans-unit id="element.singleselect-1.properties.label">
        <source>Title</source>
        <target>Anrede</target>
      </trans-unit>
      <trans-unit id="element.singleselect-1.properties.options.Mister">
        <source>Mister</source>
        <target>Herr</target>
      </trans-unit>
      <trans-unit id="element.singleselect-1.properties.options.Miss">
        <source>Miss</source>
        <target>Frau</target>
      </trans-unit>
      <trans-unit id="element.singleselect-1.properties.options.Divers">
        <source>Divers</source>
        <target>Divers</target>
      </trans-unit>

      <trans-unit id="element.text-1.properties.label">
        <source>First name</source>
        <target>Vorname</target>
