#
# BACKENDLAYOUT: DEFAULT
#
mod {
    web_layout {
        BackendLayouts {
            onboarding {
                title = LLL:EXT:stepping_stone_site_package/Resources/Private/Language/locallang_be.xlf:backend_layout.onboarding
                icon = EXT:stepping_stone_site_package/Resources/Public/Icons/BackendLayouts/onboarding.svg
                config {
                    backend_layout {
                        colCount = 2
                        rowCount = 2
                        rows {
                            1 {
                                columns {
                                    1 {
                                        name = Top
                                        colPos = 1
                                        identifier = top
                                    }
                                }
                            }
                            2 {
                                columns {
                                    1 {
                                        name = Main
                                        colPos = 0
                                        identifier = main
                                        colspan = 2
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
